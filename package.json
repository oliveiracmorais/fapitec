{
  "name": "fapitec-se-plataforma",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo da plataforma modular da FAPITEC-SE.",
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @fapitec/web run dev",
    "sync:ide": "node scripts/sync-ide.js",
    "sync:ide:check": "node scripts/sync-ide.js --check",
    "sync:skills:codex": "node scripts/sync-skills-codex.js",
    "sync:skills:codex:global": "node scripts/sync-skills-codex.js --global",
    "validate:structure": "node scripts/validate-structure.js",
    "validate:agents": "node scripts/validate-agents.js",
    "shell:modulos": "node scripts/plataforma-shell.js modulos",
    "shell:perfis": "node scripts/plataforma-shell.js perfis",
    "shell:identidades": "node scripts/plataforma-shell.js identidades",
    "shell:cadastrar": "node scripts/plataforma-shell.js cadastrar",
    "shell:login": "node scripts/plataforma-shell.js login",
    "lint": "pnpm run validate:structure && pnpm run validate:agents",
    "typecheck": "node scripts/typecheck.js",
    "test": "node --test tests/*.test.js",
    "test:go": "cd apps/api && go test ./... -v -count=1",
    "test:go:coverage": "cd apps/api && go test ./... -coverprofile=coverage.out -count=1 && go tool cover -html=coverage.out -o coverage.html",
    "build:api": "cd apps/api && go build -o bin/api ./cmd/api",
    "api": "cd apps/api && go run ./cmd/api",
    "api:make": "cd apps/api && make",
    "api:run": "cd apps/api && make run",
    "api:test": "cd apps/api && make test",
    "api:build": "cd apps/api && make build",
    "api:vet": "cd apps/api && make vet",
    "api:sqlc": "cd apps/api && make sqlc"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.32.1"
  }
}
